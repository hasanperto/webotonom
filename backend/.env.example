# Server
PORT=5000
NODE_ENV=development
# Production: deploy/.env.production.example dosyasini backend/.env olarak kullanin

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=teknopro

# JWT
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRE=7d

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Backend URL
BACKEND_URL=http://localhost:5000/api

# CORS (virgülle ayrılmış liste)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Çeviri API Key'leri (Opsiyonel)
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
USE_TRANSLATE_API=openrouter

# Dosya Yükleme
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880

# E-posta Ayarları (Opsiyonel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Ödeme Gateway'leri (Opsiyonel)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://api.iyzipay.com
