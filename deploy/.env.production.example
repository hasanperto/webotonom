# Sunucu .env — backend/.env olarak kopyalayin ve doldurun
# cp deploy/.env.production.example backend/.env

NODE_ENV=production
PORT=5000

# Veritabani (aaPanel MySQL — localhost yerine 127.0.0.1 onerilir)
DB_HOST=127.0.0.1
DB_USER=teknopro_user
DB_PASSWORD=GUCLU_SIFRE_BURAYA
DB_NAME=teknopro

# Guvenlik — mutlaka degistirin (openssl rand -hex 32)
JWT_SECRET=DEGISTIR_RASTGELE_UZUN_ANAHTAR
JWT_EXPIRE=7d

# Site adresi (https, sonunda / yok)
FRONTEND_URL=https://alanadiniz.com
BACKEND_URL=https://alanadiniz.com/api
CORS_ORIGIN=https://alanadiniz.com,https://www.alanadiniz.com

# Dosya yukleme
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760

# Ceviri (opsiyonel)
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
USE_TRANSLATE_API=openrouter

# E-posta (opsiyonel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Canli odeme (demo kapali iken doldurun)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://api.iyzipay.com
